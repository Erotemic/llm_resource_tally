#!/usr/bin/env bash
# llm_resource_tally post-commit — auto-record LLM resource usage for the commit just made.
#
# This file is the entrypoint used when core.hooksPath points at THIS directory
# (set for you by `llm_resource_tally.py install` when that is safe). It locates the tool
# relative to itself, so it keeps working no matter what the vendor dir is named.
#
# Accounting must never block or fail a commit, so it is best-effort (`|| true`) and
# stays quiet on success.
here="$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd)" || exit 0
python3 "$here/../llm_resource_tally.py" record --commit HEAD >/dev/null 2>&1 || true
